# Supabase Configuration
# To get these values:
# 1. Go to https://supabase.com
# 2. Create a new project (or use existing one)
# 3. Go to Project Settings > API
# 4. Copy the URL and anon/public key
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Groq API Configuration
# To get this key:
# 1. Go to https://console.groq.com
# 2. Sign up or log in
# 3. Navigate to API Keys section
# 4. Create a new API key
VITE_GROQ_API_KEY=your_groq_api_key_here

# Dify API Configuration
# To get these keys:
# 1. Go to https://dify.ai or your Dify instance
# 2. Create or access your application
# 3. Go to API Access settings
# 4. Generate API keys for both reviewer and general workflows
VITE_DIFY_REVIEWER_API_KEY=your_dify_reviewer_api_key_here
VITE_DIFY_GENERAL_API_KEY=your_dify_general_api_key_here
